/*
 * nds_lite.def — Key bindings for NDS Lite.
 *
 * Defines PRESET_MAP_nds_lite(X) — expanded by keybind.c via
 * KEYBIND_PRESETS to build the preset table.  Do not add #include
 * guards.
 */
#define PRESET_MAP_nds_lite(X)      \
    X(CONFIRM,       KEY_A)         \
    X(BACK,          KEY_B)         \
    X(MOD_PRIMARY,   KEY_X)         \
    X(MOD_SECONDARY, KEY_Y)         \
    X(SHOULDER_L,    KEY_L)         \
    X(SHOULDER_R,    KEY_R)         \
    X(START,         KEY_START)     \
    X(SHIFT,         KEY_SELECT)
