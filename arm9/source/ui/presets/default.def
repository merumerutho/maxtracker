/*
 * default.def — Default key bindings (standard NDS layout).
 *
 * Each line is X(action, key).  Included by keybind.c to build the
 * preset table; do not add #include guards.
 */
X(CONFIRM,       KEY_A)
X(BACK,          KEY_B)
X(MOD_PRIMARY,   KEY_X)
X(MOD_SECONDARY, KEY_Y)
X(SHOULDER_L,    KEY_L)
X(SHOULDER_R,    KEY_R)
X(START,         KEY_START)
X(SHIFT,         KEY_SELECT)
